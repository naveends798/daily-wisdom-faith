# =============================================================================
# Daily Wisdom Faith — environment variables
# Copy to .env (for local testing) or paste each into GitHub repo Secrets.
# Do NOT commit .env to git.
# =============================================================================

# --- Channel branding -------------------------------------------------------
CHANNEL_NAME="Daily Wisdom Faith"
CHANNEL_HANDLE="@DailyWisdomFaith"
NOTIFY_EMAIL="naveends798@gmail.com"
TIMEZONE="Asia/Kolkata"
PUBLISH_HOUR_LOCAL="9"

# --- Google OAuth (YouTube + Drive, single set of credentials) --------------
# Obtained from console.cloud.google.com (see SETUP.md, step 1)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# The refresh token from the one-time bootstrap. Generated by scripts/bootstrap.py.
GOOGLE_REFRESH_TOKEN=""

# --- Drive folder root ------------------------------------------------------
# ID of the parent "prayer-channel-queue" folder in your Drive.
# Auto-created and printed by bootstrap.py.
DRIVE_QUEUE_FOLDER_ID=""

# --- OpenAI (gpt-4o-mini for text metadata) ---------------------------------
OPENAI_API_BASE="https://api.openai.com/v1"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# --- Gmail SMTP (optional — failure/success notifications) ------------------
# Leave SMTP_APP_PASSWORD blank to disable email; GitHub Actions still emails
# you on workflow failures. To enable rich emails: use a Gmail App Password
# (https://myaccount.google.com/apppasswords), NOT your account password.
SMTP_USER="naveends798@gmail.com"
SMTP_APP_PASSWORD=""
